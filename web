<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
  function showPage(page, sub) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const target = document.getElementById('page-' + page);
    if (target) { target.classList.add('active'); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    document.querySelectorAll('.nav-links > li > a').forEach(a => a.classList.remove('active'));
    const navEl = document.getElementById('nav-' + page);
    if (navEl) navEl.classList.add('active');
    if (page === 'timetable' && sub) {
      setTimeout(() => {
        const tabId = sub === 'mt-gravatt' ? 'tt-btn-mtg' : 'tt-btn-we';
        const el = document.getElementById(tabId);
        if (el) el.click();
      }, 60);
    }
  }
  function toggleMobile() {
    const m = document.getElementById('mobileMenu');
    m.style.display = m.style.display === 'block' ? 'none' : 'block';
  }
  function toggleFaq(btn) {
    const a = btn.nextElementSibling;
    const wasOpen = btn.classList.contains('open');
    document.querySelectorAll('.faq-q.open').forEach(q => { q.classList.remove('open'); q.nextElementSibling.classList.remove('open'); });
    if (!wasOpen) { btn.classList.add('open'); a.classList.add('open'); }
  }
  function switchTT(btn, gridId) {
    document.querySelectorAll('.tt-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.timetable-grid').forEach(g => g.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(gridId).classList.add('active');
  }
  function openModal(location) {
    document.getElementById('modal-form-content').style.display = 'block';
    document.getElementById('modal-success').style.display = 'none';
    if (location) {
      document.getElementById('f-location').value = location;
      const loc = location === 'mt-gravatt' ? 'Mt Gravatt' : 'West End';
      document.getElementById('modal-title').textContent = 'Book Free Trial \u2014 ' + loc;
    } else {
      document.getElementById('modal-title').textContent = 'Book Your Free Trial';
    }
    document.getElementById('bookingModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    document.getElementById('bookingModal').classList.remove('open');
    document.body.style.overflow = '';
  }
  function closeModalOutside(e) {
    if (e.target === document.getElementById('bookingModal')) closeModal();
  }
  function submitBooking() {
    const first = document.getElementById('f-first').value.trim();
    const email = document.getElementById('f-email').value.trim();
    const loc = document.getElementById('f-location').value;
    if (!first) { alert('Please enter your first name.'); return; }
    if (!email || !email.includes('@')) { alert('Please enter a valid email address.'); return; }
    const locName = loc === 'mt-gravatt' ? 'Brisbane Boxing Mt Gravatt' : 'Brisbane Boxing West End';
    document.getElementById('success-name').textContent = first;
    document.getElementById('success-location').textContent = locName;
    document.getElementById('modal-form-content').style.display = 'none';
    document.getElementById('modal-success').style.display = 'block';
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
