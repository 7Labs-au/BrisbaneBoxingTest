<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brisbane Boxing | Best Boxing Gyms in Brisbane</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #e01e2e;
    --red-dark: #b01520;
    --black: #0a0a0a;
    --dark: #111111;
    --dark2: #1a1a1a;
    --dark3: #222222;
    --grey: #888;
    --light-grey: #ccc;
    --white: #ffffff;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Barlow', sans-serif; background: var(--black); color: var(--white); overflow-x: hidden; }

  .topbar {
    background: var(--dark2); border-bottom: 1px solid #2a2a2a;
    padding: 8px 32px; display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; color: var(--grey); letter-spacing: 0.5px;
  }
  .topbar-socials { display: flex; gap: 18px; }
  .topbar-socials a {
    color: var(--grey); text-decoration: none;
    font-family: 'Barlow Condensed', sans-serif; font-size: 12px;
    font-weight: 700; letter-spacing: 1px; text-transform: uppercase; transition: color 0.2s;
  }
  .topbar-socials a:hover { color: var(--white); }

  nav {
    background: var(--black); border-bottom: 1px solid #1c1c1c;
    position: sticky; top: 0; z-index: 1000;
    padding: 0 32px; display: flex; align-items: center;
    justify-content: space-between; height: 68px;
  }
  .nav-logo { cursor: pointer; display: flex; align-items: center; }
  .nav-logo img { height: 38px; width: auto; }
  .nav-logo-fallback {
    font-family: 'Barlow Condensed', sans-serif; font-size: 22px;
    font-weight: 900; letter-spacing: 2px; text-transform: uppercase; color: white;
  }
  .nav-logo-fallback span { color: var(--red); }

  .nav-links { display: flex; align-items: center; list-style: none; height: 100%; }
  .nav-links > li { position: relative; height: 100%; display: flex; align-items: center; }
  .nav-links > li > a, .nav-links > li > span {
    display: flex; align-items: center; gap: 3px;
    padding: 0 12px; height: 100%;
    font-family: 'Barlow Condensed', sans-serif; font-size: 12px;
    font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase;
    color: #aaa; text-decoration: none; cursor: pointer; transition: color 0.2s; white-space: nowrap;
  }
  .nav-links > li > a:hover, .nav-links > li > span:hover, .nav-links > li > a.active { color: var(--white); }
  .nav-links > li > span::after { content: ' ▾'; font-size: 8px; opacity: 0.5; }
  .dropdown {
    display: none; position: absolute; top: 68px; left: 0;
    background: var(--dark2); border: 1px solid #2a2a2a; border-top: 2px solid var(--red);
    min-width: 230px; z-index: 999; padding: 6px 0;
    box-shadow: 0 12px 40px rgba(0,0,0,0.6);
  }
  .nav-links > li:hover .dropdown { display: block; }
  .dropdown a {
    display: block; padding: 10px 20px;
    font-family: 'Barlow Condensed', sans-serif; font-size: 12px;
    font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    color: #aaa; text-decoration: none; transition: all 0.15s; cursor: pointer;
  }
  .dropdown a:hover { color: var(--white); background: #252525; padding-left: 26px; }
  .nav-cta { background: var(--red) !important; color: var(--white) !important; padding: 0 14px !important; font-weight: 800 !important; }
  .nav-cta:hover { background: var(--red-dark) !important; }

  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 8px; }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--white); }
  .mobile-menu { display: none; background: var(--dark); border-top: 1px solid #222; padding: 12px 0; }
  .mobile-menu a {
    display: block; padding: 12px 24px;
    font-family: 'Barlow Condensed', sans-serif; font-size: 13px;
    font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase;
    color: #aaa; text-decoration: none; cursor: pointer; border-bottom: 1px solid #1e1e1e;
  }
  .mobile-menu a:hover { color: var(--white); background: #1a1a1a; }
  .mobile-menu .mm-sub { padding-left: 38px; font-size: 11px; }

  .page { display: none; }
  .page.active { display: block; animation: fadeUp 0.3s ease; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--red); color: var(--white); padding: 14px 28px;
    font-family: 'Barlow Condensed', sans-serif; font-size: 13px;
    font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase;
    text-decoration: none; cursor: pointer; border: none;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--red-dark); transform: translateY(-1px); }
  .btn-outline {
    display: inline-flex; align-items: center; gap: 8px;
    background: transparent; color: var(--white); padding: 13px 28px;
    font-family: 'Barlow Condensed', sans-serif; font-size: 13px;
    font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase;
    text-decoration: none; cursor: pointer; border: 2px solid #444; transition: border-color 0.2s;
  }
  .btn-outline:hover { border-color: var(--white); }

  /* HERO */
  .hero {
    position: relative; height: 92vh; min-height: 580px;
    display: flex; align-items: center; overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.93) 38%, rgba(0,0,0,0.35) 100%),
      url('https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=1600&q=80') center/cover;
  }
  .hero-bg::after {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.02) 3px, rgba(0,0,0,0.02) 4px);
  }
  .hero-content { position: relative; z-index: 2; padding: 0 64px; max-width: 800px; }
  .hero-logo { height: 60px; width: auto; margin-bottom: 28px; display: block; }
  .hero-eyebrow {
    font-family: 'Barlow Condensed', sans-serif; font-size: 12px;
    font-weight: 700; letter-spacing: 4px; text-transform: uppercase;
    color: var(--red); margin-bottom: 16px;
    display: flex; align-items: center; gap: 12px;
  }
  .hero-eyebrow::before { content: ''; display: block; width: 28px; height: 2px; background: var(--red); }
  .hero h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(64px, 9vw, 118px); font-weight: 900;
    line-height: 0.88; text-transform: uppercase; letter-spacing: -1px; margin-bottom: 24px;
  }
  .hero h1 em { font-style: italic; color: var(--red); }
  .hero p { font-size: 17px; color: #999; line-height: 1.65; max-width: 500px; margin-bottom: 34px; }
  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-stats {
    position: absolute; bottom: 52px; right: 64px;
    display: flex; gap: 44px; z-index: 2;
  }
  .stat { text-align: center; }
  .stat-num { font-family: 'Barlow Condensed', sans-serif; font-size: 44px; font-weight: 900; line-height: 1; }
  .stat-num span { color: var(--red); }
  .stat-label { font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase; color: var(--grey); margin-top: 4px; }

  section { padding: 80px 64px; }
  .section-label {
    font-family: 'Barlow Condensed', sans-serif; font-size: 11px;
    font-weight: 700; letter-spacing: 4px; text-transform: uppercase;
    color: var(--red); margin-bottom: 10px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before { content: ''; display: block; width: 22px; height: 2px; background: var(--red); }
  .section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(38px, 5vw, 60px); font-weight: 900;
    text-transform: uppercase; line-height: 0.93; letter-spacing: -0.5px; margin-bottom: 18px;
  }
  .section-title em { color: var(--red); font-style: italic; }
  .section-subtitle { color: var(--grey); font-size: 15px; line-height: 1.7; max-width: 580px; margin-bottom: 44px; }

  /* ABOUT */
  .about-section { background: var(--dark); display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .about-img-wrap { position: relative; }
  .about-img { width: 100%; aspect-ratio: 4/5; object-fit: cover; display: block; position: relative; z-index: 1; }
  .about-img-wrap::before {
    content: ''; position: absolute; top: -14px; left: -14px; right: 14px; bottom: 14px;
    border: 2px solid var(--red); z-index: 0;
  }

  /* GYMS */
  .gyms-section { background: var(--black); }
  .gyms-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3px; margin-top: 48px; }
  .gym-card { position: relative; overflow: hidden; cursor: pointer; }
  .gym-card-img { width: 100%; aspect-ratio: 16/11; object-fit: cover; display: block; transition: transform 0.5s ease; }
  .gym-card:hover .gym-card-img { transform: scale(1.04); }
  .gym-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.92) 36%, rgba(0,0,0,0.1) 100%); }
  .gym-card-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 32px; }
  .gym-card-tag { font-family: 'Barlow Condensed', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--red); margin-bottom: 6px; }
  .gym-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 38px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px; }
  .gym-card-links { display: flex; gap: 8px; flex-wrap: wrap; }
  .gym-card-links a {
    font-family: 'Barlow Condensed', sans-serif; font-size: 11px;
    font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--white); text-decoration: none; border: 1px solid rgba(255,255,255,0.25);
    padding: 6px 14px; transition: all 0.2s; cursor: pointer;
  }
  .gym-card-links a:hover { background: var(--red); border-color: var(--red); }

  /* CLASSES GRID */
  .classes-section { background: var(--dark); }
  .classes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; margin-top: 44px; }
  .class-card { position: relative; overflow: hidden; cursor: pointer; border-top: 3px solid transparent; transition: border-top-color 0.25s; }
  .class-card:hover { border-top-color: var(--red); }
  .class-card-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; transition: transform 0.45s ease; filter: brightness(0.72); }
  .class-card:hover .class-card-img { transform: scale(1.04); filter: brightness(0.6); }
  .class-card-body { background: var(--dark2); padding: 22px 22px 26px; }
  .class-card-body h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 21px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; color: var(--white); margin-bottom: 7px; }
  .class-card-body p { font-size: 13px; color: var(--grey); line-height: 1.6; margin-bottom: 13px; }
  .class-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .class-tag { font-family: 'Barlow Condensed', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--red); border: 1px solid rgba(224,30,46,0.35); padding: 3px 9px; }

  /* APP */
  .app-section { background: var(--red); display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .app-section .section-label { color: rgba(255,255,255,0.65); }
  .app-section .section-label::before { background: rgba(255,255,255,0.65); }
  .app-section .section-subtitle { color: rgba(255,255,255,0.8); }
  .app-badges { display: flex; gap: 12px; flex-wrap: wrap; }
  .app-badge { background: var(--black); color: var(--white); padding: 13px 22px; font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; display: flex; align-items: center; gap: 10px; text-decoration: none; transition: background 0.2s; }
  .app-badge:hover { background: #111; }
  .app-visual { background: rgba(0,0,0,0.2); aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-family: 'Barlow Condensed', sans-serif; font-size: 80px; font-weight: 900; color: rgba(255,255,255,0.1); }

  /* PUNCHES */
  .punches-section { background: var(--black); }
  .punches-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 3px; margin-top: 44px; }
  .punch-card { background: var(--dark2); padding: 28px 18px; text-align: center; border-bottom: 3px solid transparent; transition: border-color 0.2s; }
  .punch-card:hover { border-bottom-color: var(--red); }
  .punch-num { font-family: 'Barlow Condensed', sans-serif; font-size: 64px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 8px; }
  .punch-name { font-family: 'Barlow Condensed', sans-serif; font-size: 15px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
  .punch-sub { font-size: 11px; color: var(--grey); }

  /* PRICING */
  .pricing-section { background: var(--dark); }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; max-width: 1020px; margin: 0 auto 40px; }
  .price-card { background: var(--dark2); padding: 40px 32px; position: relative; border-top: 3px solid transparent; }
  .price-card.featured { background: var(--dark3); border-top-color: var(--red); }
  .price-badge { position: absolute; top: -1px; right: 20px; background: var(--red); font-family: 'Barlow Condensed', sans-serif; font-size: 10px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; padding: 4px 12px; color: var(--white); }
  .price-tag-label { font-family: 'Barlow Condensed', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--grey); margin-bottom: 6px; }
  .price-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; text-transform: uppercase; margin-bottom: 4px; }
  .price-card .sub { font-size: 13px; color: var(--grey); margin-bottom: 22px; }
  .price-amount { display: flex; align-items: flex-start; gap: 3px; margin-bottom: 22px; }
  .price-dollar { font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 700; color: var(--grey); margin-top: 8px; }
  .price-num { font-family: 'Barlow Condensed', sans-serif; font-size: 52px; font-weight: 900; line-height: 1; }
  .price-period { font-size: 12px; color: var(--grey); align-self: flex-end; padding-bottom: 5px; }
  .price-features { list-style: none; margin-bottom: 28px; }
  .price-features li { font-size: 13px; color: #bbb; padding: 8px 0; border-bottom: 1px solid #252525; display: flex; gap: 10px; align-items: flex-start; }
  .price-features li::before { content: '—'; color: var(--red); font-size: 11px; flex-shrink: 0; margin-top: 2px; }
  .price-note { font-size: 11px; color: #555; margin-top: 10px; line-height: 1.5; }
  .pricing-cta-box { background: var(--black); padding: 40px; text-align: center; max-width: 1020px; margin: 0 auto; border-top: 2px solid #1a1a1a; }
  .pricing-cta-box h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 28px; font-weight: 800; text-transform: uppercase; margin-bottom: 10px; }
  .pricing-cta-box p { color: var(--grey); margin-bottom: 22px; font-size: 14px; }
  .pricing-cta-box .btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* PT */
  .pt-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; margin-top: 44px; }
  .pt-card { background: var(--dark2); padding: 36px 28px; border-top: 3px solid transparent; position: relative; }
  .pt-card.featured { border-top-color: var(--red); }
  .pt-duration { font-family: 'Barlow Condensed', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--grey); margin-bottom: 6px; }
  .pt-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 21px; font-weight: 800; text-transform: uppercase; margin-bottom: 4px; }
  .pt-price { font-family: 'Barlow Condensed', sans-serif; font-size: 46px; font-weight: 900; margin: 14px 0; }
  .pt-price span { font-size: 18px; color: var(--grey); }
  .pt-card ul { list-style: none; margin-bottom: 26px; }
  .pt-card ul li { font-size: 13px; color: #bbb; padding: 7px 0; border-bottom: 1px solid #252525; display: flex; gap: 8px; }
  .pt-card ul li::before { content: '—'; color: var(--red); font-size: 11px; flex-shrink: 0; }
  .pt-card .btns { display: flex; gap: 8px; flex-direction: column; }

  /* FAQ */
  .faq-list { max-width: 880px; }
  .faq-item { border-bottom: 1px solid #1e1e1e; }
  .faq-q { width: 100%; background: none; border: none; color: var(--white); text-align: left; padding: 20px 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-family: 'Barlow Condensed', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; transition: color 0.2s; }
  .faq-q:hover { color: var(--red); }
  .faq-q .icon { font-size: 20px; transition: transform 0.25s; color: var(--red); line-height: 1; }
  .faq-q.open .icon { transform: rotate(45deg); }
  .faq-a { display: none; padding: 0 0 20px; color: var(--grey); font-size: 14px; line-height: 1.75; max-width: 700px; }
  .faq-a.open { display: block; }

  /* CONTACT */
  .locations-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3px; margin-top: 44px; }
  .location-card { background: var(--dark2); padding: 40px; border-top: 3px solid var(--red); }
  .location-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 28px; font-weight: 800; text-transform: uppercase; margin-bottom: 24px; }
  .location-detail { display: flex; gap: 14px; margin-bottom: 16px; align-items: flex-start; }
  .location-detail .ico { font-size: 13px; flex-shrink: 0; margin-top: 3px; color: var(--red); }
  .location-detail-text strong { display: block; font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--grey); margin-bottom: 3px; }
  .location-detail-text span { font-size: 14px; color: var(--light-grey); }
  .location-hours { margin: 22px 0; }
  .hours-label { font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--grey); margin-bottom: 10px; }
  .hours-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #252525; font-size: 13px; }
  .hours-row .day { color: var(--grey); }
  .hours-row .time { color: var(--light-grey); font-weight: 600; }

  /* TIMETABLE */
  .timetable-tabs { display: flex; gap: 0; margin-bottom: 28px; }
  .tt-tab { padding: 12px 28px; font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; background: var(--dark2); color: var(--grey); border: none; transition: all 0.2s; border-bottom: 3px solid transparent; }
  .tt-tab.active { color: var(--white); border-bottom-color: var(--red); background: var(--dark3); }
  .timetable-grid { display: none; }
  .timetable-grid.active { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
  .tt-day-header { background: var(--dark3); padding: 14px 10px; font-family: 'Barlow Condensed', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; text-align: center; color: var(--grey); }
  .tt-class { background: var(--dark2); padding: 11px 10px; margin-top: 2px; border-left: 3px solid var(--red); }
  .tt-class-name { font-family: 'Barlow Condensed', sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--white); margin-bottom: 2px; }
  .tt-class-time { font-size: 11px; color: var(--grey); }
  .tt-class.kids { border-left-color: #f59e0b; }
  .tt-class.womens { border-left-color: #ec4899; }
  .tt-class.fighters { border-left-color: #3b82f6; }

  /* PAGE HEADER */
  .page-header { background: var(--dark); padding: 60px 64px 44px; border-bottom: 1px solid #1c1c1c; position: relative; overflow: hidden; }
  .page-header::before { content: attr(data-text); position: absolute; right: -10px; top: 50%; transform: translateY(-50%); font-family: 'Barlow Condensed', sans-serif; font-size: 140px; font-weight: 900; text-transform: uppercase; color: rgba(255,255,255,0.022); line-height: 1; pointer-events: none; white-space: nowrap; }
  .page-header .section-label, .page-header h1, .page-header p { position: relative; }
  .page-header h1 { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(42px, 6vw, 74px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.5px; }
  .page-header p { color: var(--grey); font-size: 15px; line-height: 1.7; max-width: 640px; margin-top: 14px; }

  /* STEPS */
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; margin-top: 44px; }
  .step-card { background: var(--dark2); padding: 38px 30px; border-top: 3px solid #252525; transition: border-top-color 0.2s; }
  .step-card:hover { border-top-color: var(--red); }
  .step-num { font-family: 'Barlow Condensed', sans-serif; font-size: 52px; font-weight: 900; color: var(--red); opacity: 0.35; line-height: 1; margin-bottom: 8px; }
  .step-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px; }
  .step-card ul { list-style: none; }
  .step-card ul li { font-size: 13px; color: var(--grey); padding: 7px 0; border-bottom: 1px solid #252525; display: flex; gap: 10px; align-items: flex-start; }
  .step-card ul li::before { content: '—'; color: var(--red); font-size: 11px; flex-shrink: 0; margin-top: 2px; }

  /* CLASS DETAIL */
